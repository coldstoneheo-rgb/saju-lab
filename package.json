{
  "name": "saju-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Report-first Four Pillars analysis workspace.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "collect:solar-terms": "python scripts/collect_public_data_solar_terms.py",
    "verify": "npm run typecheck && npm test && npm run build && npm audit --audit-level=moderate && git diff --check",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
